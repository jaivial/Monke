{
  "name": "monke",
  "version": "0.1.0",
  "description": "MONKE — Multiplier of Operations Non Kernel and Effective. Disk-routed LLM chat, runs on CPU + SSD from a flash drive.",
  "author": "MONKE",
  "license": "Apache-2.0",
  "main": "dist-electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -p tsconfig.node.json && vite build && electron-builder",
    "build:renderer": "vite build",
    "build:electron": "tsc -p tsconfig.node.json",
    "native": "node native/build.mjs",
    "bootstrap": "node bootstrap/bootstrap.mjs",
    "check": "node bootstrap/bootstrap.mjs --check",
    "start": "electron .",
    "dist": "npm run build:electron && npm run build:renderer && electron-builder -mwl"
  },
  "dependencies": {
    "@assistant-ui/react": "^0.7.0",
    "@assistant-ui/react-markdown": "^0.7.0",
    "better-sqlite3": "^11.3.0",
    "lucide-react": "^0.454.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.47",
    "tailwindcss": "^3.4.14",
    "typescript": "^5.6.3",
    "vite": "^5.4.9",
    "vite-plugin-electron": "^0.28.8",
    "vite-plugin-electron-renderer": "^0.14.6"
  },
  "build": {
    "appId": "ai.monke.app",
    "productName": "MONKE",
    "files": ["dist", "dist-electron", "assets/**", "native/**"],
    "extraResources": [
      { "from": "native/bin", "to": "native/bin" },
      { "from": "model", "to": "model", "filter": ["**/*"] }
    ],
    "directories": { "output": "release" },
    "mac": { "target": ["dmg", "zip"], "category": "public.app-category.developer-tools" },
    "win": { "target": ["nsis", "portable"] },
    "linux": { "target": ["AppImage", "deb"], "category": "Utility" }
  }
}
